{
  "name": "kr-router",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist",
    "build:core": "tsc -b configs/tsconfig.cjs.json configs/tsconfig.esm.json configs/tsconfig.types.json",
    "build:subpackages": "tsc -b configs/react.tsconfig.cjs.json configs/react.tsconfig.esm.json configs/react.tsconfig.types.json configs/preact.tsconfig.cjs.json configs/preact.tsconfig.esm.json configs/preact.tsconfig.types.json",
    "build:main": "npm run build:core && npm run build:subpackages",
    "generate": "node --import tsx ./scripts/genPackageFiles.ts",
    "build": "npm-run-all clean build:main",
    "test-watch": "npm run build && node --import tsx --test --test-reporter=spec --watch src/test/*.test.*",
    "analyze:js": "eslint ./src",
    "format:js": "eslint --fix ./packages",
    "check-types": "tsc --noEmit",
    "gen-coverage-badge": "node --import tsx ./scripts/genCoverageBadge.ts",
    "gen-size-badge": "node --import tsx ./scripts/genSizeBadges.ts",
    "test-ts": "c8 node --import tsx --test --experimental-strip-types --test-reporter=spec ./src/**/*.test.ts && npm run gen-coverage-badge"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "devDependencies": {
    "@espcom/esbuild-plugin-compress": "1.2.0",
    "@espcom/eslint-config": "latest",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "badge-maker": "4.0.0",
    "c8": "10.1.2",
    "esbuild": "0.25.5",
    "husky": "9.1.5",
    "lint-staged": "15.2.9",
    "npm-run-all": "^4.1.5",
    "preact": "^10.29.0",
    "react": "^19.2.4",
    "tsx": "4.21.0",
    "typescript": "^5.3.3",
    "xml-splitter": "1.2.1"
  },
  "sideEffect": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    },
    "./react": {
      "types": "./dist/types/react/index.d.ts",
      "require": "./dist/cjs/react/index.js",
      "import": "./dist/esm/react/index.js"
    },
    "./preact": {
      "types": "./dist/types/preact/index.d.ts",
      "require": "./dist/cjs/preact/index.js",
      "import": "./dist/esm/preact/index.js"
    }
  }
}
