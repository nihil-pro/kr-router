{
  "include": ["src/**/*", "scripts", "eslint.config.mjs", "lint-staged.config.mjs"],
  "exclude": ["src/test/*"],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "DOM.Iterable", "DOM"],
    "outDir": "dist",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "jsx": "react",
    "strict": true,
    "strictNullChecks": true,
    "paths": {
      "kr-router": ["src/index.ts"]
    }
  }
}